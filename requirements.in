# Runtime dependencies — what the application needs to run.
# Compiled into requirements.txt via pip-compile.
# This file is used by the Dockerfile for production builds.

# LLM providers
anthropic
openai
google-genai
google-antigravity  # agy local runtime SDK; imported lazily in engine.py (optional at runtime)

# Async / networking
aiohttp
aiolimiter
fastapi
uvicorn
httpx

# Bot interfaces
discord.py
google-auth
google-auth-oauthlib
google-cloud-pubsub
google-api-python-client  # googleapiclient

# Numerical
numpy

# Utilities
python-dotenv
requests
ddgs
sqlite-vec
