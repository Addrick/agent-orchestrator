# Base runtime dependencies — the lean core the application needs to run.
# Compiled into requirements.txt via pip-compile.
#
# DP-250: the heavy voice/STT stack (discord-ext-voice-recv, useful-moonshine-onnx
# and their ML transitive deps: numba/onnxruntime/scikit-learn/librosa/...) lives
# in requirements-voice.in, NOT here, so CI (which installs requirements-dev.txt,
# inheriting THIS file) stays lean and avoids the heavy/py-version-fragile ML
# wheels. Production installs requirements-voice.txt (base + voice). See the
# Dockerfile and requirements-voice.in.

# LLM providers
anthropic
openai
google-genai
# NOTE: the `agy` engine route uses the `agy` CLI via subprocess (no Python SDK),
# so google-antigravity is intentionally NOT a dependency.

# Async / networking
aiohttp
aiolimiter
fastapi
starlette>=1.3.1  # imported directly in voice/web.py (WebSocketState); FastAPI's ASGI base. >=1.3.1: form()-limit DoS (high) + url.hostname poisoning (low) CVEs, DP-251
uvicorn
httpx

# Bot interfaces
discord.py
google-auth
audioop-lts ; python_version >= "3.13"  # stdlib audioop removed in 3.13+; needed by discord.py
google-auth-oauthlib
google-cloud-pubsub
google-api-python-client  # googleapiclient

# Numerical
numpy

# Utilities
python-dotenv
requests
ddgs
sqlite-vec
