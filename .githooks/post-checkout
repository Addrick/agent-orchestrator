#!/bin/sh
# Auto-populate gitignored essentials into new worktrees.
#
# `git worktree add` does NOT copy gitignored files, but it DOES run this
# post-checkout hook inside the freshly-created worktree (with $3 = 1, a branch
# checkout). Worktrees share one hooks dir, so this one hook serves every
# worktree. We copy the gitignored config the app/tests need (.env, .env.test)
# from the MAIN worktree into the new one.
#
# Idempotent + safe: only copies a file that is ABSENT here and PRESENT in the
# main worktree, and no-ops entirely when run in the main worktree itself. So it
# never clobbers an edited .env and is harmless on ordinary `git checkout`.
#
# Tracked + activated via `core.hooksPath=.githooks` (see scripts/setup-hooks.sh).

# $1 old HEAD, $2 new HEAD, $3 flag (1 = branch checkout, incl. worktree add)
[ "$3" = "1" ] || exit 0

common=$(git rev-parse --git-common-dir 2>/dev/null) || exit 0
main_root=$(cd "$(dirname "$common")" 2>/dev/null && pwd) || exit 0
here=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0

# In the main worktree there is nothing to populate.
[ "$main_root" = "$here" ] && exit 0

for f in .env .env.test; do
  if [ ! -e "$here/$f" ] && [ -f "$main_root/$f" ]; then
    cp "$main_root/$f" "$here/$f" && echo "[post-checkout] seeded $f into worktree"
  fi
done

# Build a real, isolated per-worktree venv with uv. uv hardlinks packages from
# its global cache, so this is near-instant and cheap on disk — and because it's
# a REAL venv (not a junction into the main .venv), `git worktree remove` and
# `rm -rf` are always safe: no junction-drop teardown ritual, no risk of nuking
# the shared venv. Deps come from the worktree's own requirements*.txt, so a
# branch that changes deps gets the right ones. Requires uv
# (https://docs.astral.sh/uv/); if it's missing we warn and skip rather than
# block the checkout.
if [ ! -e "$here/.venv" ]; then
  if command -v uv >/dev/null 2>&1; then
    reqs=""
    [ -f "$here/requirements.txt" ] && reqs="$reqs -r requirements.txt"
    [ -f "$here/requirements-dev.txt" ] && reqs="$reqs -r requirements-dev.txt"
    if ( cd "$here" \
         && uv venv .venv >/dev/null 2>&1 \
         && VIRTUAL_ENV="$here/.venv" uv pip install --quiet $reqs ); then
      echo "[post-checkout] created isolated venv via uv"
    else
      echo "[post-checkout] WARN: uv venv/install failed — create .venv manually"
    fi
  else
    echo "[post-checkout] WARN: uv not found — no .venv created (install uv: https://docs.astral.sh/uv/)"
  fi
fi

exit 0
